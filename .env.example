# Copy to .env for local development

# Security — use a long random string in production (32+ chars)
JWT_SECRET=change-this-to-a-long-random-secret-string

# GitHub token (optional but strongly recommended)
# Without: 60 requests/hour | With: 5,000 requests/hour
# Get one at: https://github.com/settings/tokens
# Required scopes: public_repo, read:user
GITHUB_TOKEN=

# Environment: development | production
ENVIRONMENT=development

# Server port
PORT=8000

# Optional: custom SQLite path (default: ./skillledger.db)
DB_PATH=
